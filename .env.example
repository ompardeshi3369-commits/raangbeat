VITE_SUPABASE_PROJECT_ID="your_supabase_project_id_here"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key_here"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# YouTube Data API v3 — Multiple keys for maximum coverage
# Each key = 10,000 free units/day from a separate Google Cloud project
# Get keys from: https://console.cloud.google.com/ → Enable "YouTube Data API v3"
VITE_YOUTUBE_API_KEY_1="your_youtube_api_key_1_here"
VITE_YOUTUBE_API_KEY_2="your_youtube_api_key_2_here"
VITE_YOUTUBE_API_KEY_3="your_youtube_api_key_3_here"
VITE_YOUTUBE_API_KEY_4=""
VITE_YOUTUBE_API_KEY_5=""

# Genius API — for song metadata & lyrics page links
# Get at: https://genius.com/api-clients
VITE_GENIUS_API_KEY="your_genius_api_key_here"

# Gemini API — for AI features
VITE_GEMINI_API_KEY="your_gemini_api_key_here"
